            </property>
           </widget>
          </item>
          <item row="0" column="1">
           <widget class="qMRMLNodeComboBox" name="sourceMeshSelector">
            <property name="toolTip">
             <string>Mesh to align. Place landmarks on source matching reference (1-5), then apply.</string>
            </property>
            <property name="nodeTypes">
             <stringlist notr="true">
